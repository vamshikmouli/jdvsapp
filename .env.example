# ---------------------------------------------------------------------------
# Jnana Deepika ERP — environment variables
# Copy to .env.local for local dev. In production set these in the Vercel
# dashboard (Project → Settings → Environment Variables). Never commit secrets.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# DATABASE_URL = the POOLED connection (used at runtime by serverless functions).
#   On Supabase: Project → Settings → Database → "Connection pooling" (port 6543),
#   and append ?pgbouncer=true&connection_limit=1
# DIRECT_URL   = the DIRECT connection (port 5432) — used only by `prisma db push`.
#   On a single VPS (Oracle Cloud) both can be the same direct URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- NextAuth ---
# NEXTAUTH_URL must be the public site URL (https://your-domain). No trailing slash.
# NEXTAUTH_SECRET: generate with `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
NEXTAUTH_URL="https://your-domain.example"
NEXTAUTH_SECRET="CHANGE_ME"

# --- File uploads (student photos) ---
# Set these to use Supabase Storage (required on Vercel — its filesystem is ephemeral).
# Leave them BLANK to fall back to local disk (local dev or a VPS with a persistent disk).
# Create a PUBLIC bucket named "uploads" in Supabase Storage. Use the SERVICE ROLE key
# (server-only secret — never expose to the browser).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"

# --- Web Push (VAPID) — parent push notifications ---
# Generate a fresh pair with `npx web-push generate-vapid-keys`. Do NOT reuse the dev keys.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@your-domain.example"
